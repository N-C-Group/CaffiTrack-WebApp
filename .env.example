# CaffiTrack Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Admin Panel (required for admin features)
ADMIN_PIN=your-secure-pin

# Mobile API (required for /api/caffeineItems endpoint used by the app)
CAFFEINE_API_KEY=your-secure-api-key

# Firebase Cloud Messaging (required for push notifications)
# Paste your Firebase service account JSON as a single line, or use base64
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Email - Resend (required for contact form & request status emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=CaffiTrack <notifications@yourdomain.com>
# Where to receive contact form submissions (defaults to RESEND_FROM_EMAIL if not set)
RESEND_CONTACT_TO=your-email@gmail.com

# Optional: GitHub (only for create-repo script)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Optional: Public URL for OpenGraph/twitter meta images (e.g. https://caffitrack.com)
# SITE_URL=https://your-domain.com
